#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
IMAGE="oo-test:local"

if ! command -v docker >/dev/null 2>&1; then
  echo "[error] docker is required for integration tests." >&2
  exit 1
fi

docker build -t "$IMAGE" -f "$ROOT_DIR/tests/integration/docker/Dockerfile.test" "$ROOT_DIR"
docker run --rm -v "$ROOT_DIR:/workspace" -w /workspace "$IMAGE" bats tests/integration/docker
